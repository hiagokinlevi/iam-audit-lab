# iam-audit-lab — Environment Configuration
# =========================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# NEVER store cloud credentials in this file — use provider credential chains instead.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
PROVIDER=aws  # aws, azure, gcp, entra

# ---------------------------------------------------------------------------
# AWS configuration
# ---------------------------------------------------------------------------
# Uses the standard boto3 credential chain:
# 1. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# 2. AWS profile (set below)
# 3. IAM instance role (if running on EC2)
AWS_PROFILE=default
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Azure / Entra configuration
# ---------------------------------------------------------------------------
# Uses azure-identity DefaultAzureCredential credential chain.
# Set these for service principal authentication.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ---------------------------------------------------------------------------
# GCP configuration
# ---------------------------------------------------------------------------
# Path to a service account JSON key file.
# Alternative: use Application Default Credentials (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# ---------------------------------------------------------------------------
# Audit configuration
# ---------------------------------------------------------------------------
INCLUDE_INACTIVE_ANALYSIS=true        # Run inactive account analysis
INCLUDE_MFA_ANALYSIS=true             # Run MFA coverage analysis
INACTIVE_THRESHOLD_DAYS=90            # Days of inactivity before flagging an account

# Risk scoring: how much each factor contributes to the overall risk score.
# Values are weights (0.0–1.0) and should sum to 1.0.
RISK_SCORING_WEIGHTS_PRIVILEGE=0.4    # Weight for privilege level in risk score

# Report settings
OUTPUT_DIR=./output                   # Directory for generated reports
REPORT_VERBOSITY=standard             # standard, verbose, executive_only
REDACT_IDENTIFIABLE_FIELDS=false      # Set to true to pseudonymize user names in reports
